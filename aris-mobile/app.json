{
  "expo": {
    "name": "ARIS Nexus",
    "slug": "aris-nexus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/aris-icon.png",
    "scheme": "arisnexus",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tattvaedge.arisnexus"
    },

    "android": {
      "package": "com.tattvaedge.arisnexus",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#061633",
          "dark": {
            "backgroundColor": "#061633"
          }
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "API_URL": "https://aris-live-production.up.railway.app",
      "router": {},
      "eas": {
        "projectId": "4bb64bb0-370b-43f0-a843-70bdd6596d42"
      }
    },

    "owner": "arisnexus"
  }
}